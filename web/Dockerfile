# Build context must be the repo root (web references ../Laevitas.StandaloneClient)
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY Laevitas.StandaloneClient/ ./Laevitas.StandaloneClient/
COPY web/ ./web/
RUN dotnet restore web/LaevitasWeb.csproj
RUN dotnet publish web/LaevitasWeb.csproj -c Release -o /app /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app .
ENV ASPNETCORE_URLS=http://0.0.0.0:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "LaevitasWeb.dll"]
