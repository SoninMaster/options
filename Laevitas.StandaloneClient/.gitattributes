# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Force CRLF for Windows-specific files
*.sln       text eol=crlf
*.csproj    text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Source files
*.cs        text diff=csharp
*.json      text
*.md        text
*.yml       text
*.yaml      text

# Binary files
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.snk       binary
*.pfx       binary
